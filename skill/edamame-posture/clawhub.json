{
  "name": "edamame-posture",
  "version": "2.0.0",
  "description": "Thin EDAMAME Posture MCP facade for OpenClaw. Exposes posture, telemetry, divergence, and remediation endpoints directly. The agentic remediation loop is enabled inside EDAMAME by default; this skill does not implement an OpenClaw-side remediation cron.",
  "tagline": "EDAMAME Posture MCP facade for OpenClaw",
  "category": "security",
  "author": "EDAMAME Technologies",
  "license": "MIT",
  "homepage": "https://github.com/edamametechnologies/openclaw_security",
  "repository": "https://github.com/edamametechnologies/openclaw_security",
  "support_url": "https://github.com/edamametechnologies/openclaw_security/issues",
  "entry": "SKILL.md",
  "minOpenClawVersion": "0.8.0",
  "tags": [
    "security", "posture", "mcp", "edamame", "advisor", "telemetry", "divergence"
  ],
  "requires": {
    "tools": [
      "advisor_get_todos", "advisor_get_action_history", "get_score",
      "agentic_get_workflow_status", "agentic_process_todos", "agentic_execute_action",
      "advisor_undo_action", "advisor_undo_all_actions",
      "get_sessions", "get_anomalous_sessions", "get_blacklisted_sessions", "get_exceptions",
      "get_lan_devices", "get_lan_host_device", "set_lan_auto_scan",
      "get_breaches", "get_pwned_emails", "add_pwned_email", "remove_pwned_email",
      "get_divergence_verdict", "get_divergence_history",
      "get_divergence_engine_status",
      "send_alert"
    ],
    "bins": ["edamame_posture"],
    "external": ["edamame_posture"]
  },
  "install": [
    {
      "id": "brew",
      "kind": "brew",
      "formula": "edamametechnologies/tap/edamame-posture",
      "bins": ["edamame_posture"],
      "label": "Install EDAMAME Posture (brew)",
      "os": ["darwin"]
    },
    {
      "id": "shell-linux",
      "kind": "shell",
      "command": "curl --proto '=https' --tlsv1.2 -sSf https://raw.githubusercontent.com/edamametechnologies/edamame_posture/main/install.sh | sh",
      "bins": ["edamame_posture"],
      "label": "Install EDAMAME Posture (Linux)",
      "os": ["linux"]
    }
  ],
  "security": {
    "shell_commands": [],
    "mcp_tools": [
      "advisor_get_todos", "advisor_get_action_history", "get_score",
      "agentic_get_workflow_status", "agentic_process_todos", "agentic_execute_action",
      "advisor_undo_action", "advisor_undo_all_actions",
      "get_sessions", "get_anomalous_sessions", "get_blacklisted_sessions", "get_exceptions",
      "get_lan_devices", "get_lan_host_device", "set_lan_auto_scan",
      "get_breaches", "get_pwned_emails", "add_pwned_email", "remove_pwned_email",
      "get_divergence_verdict", "get_divergence_history",
      "get_divergence_engine_status"
    ],
    "external_endpoints": ["http://127.0.0.1:3000/mcp (local EDAMAME MCP server, PSK-authenticated)"],
    "file_operations": [],
    "environment_variables": [],
    "credential_access": false,
    "network_egress": false,
    "persistence": false,
    "notes": "This skill is a thin MCP facade. It exposes EDAMAME posture/telemetry/divergence/action APIs directly and does not store security state in local workspace memory files. Security-critical state remains inside EDAMAME process memory and is accessed through authenticated MCP endpoints. Loop lifecycle control (agentic/divergence start-stop and interval) is CLI-only via edamame_posture."
  }
}
